# ─── Database ───────────────────────────────────────────
DATABASE_URL=postgresql://skillhub:skillhub@localhost:5433/skillhub

# ─── Auth ──────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
STUB_AUTH_ENABLED=false

# ─── CORS ──────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# ─── OAuth (production) ───────────────────────────────
OAUTH_MICROSOFT_CLIENT_ID=
OAUTH_MICROSOFT_CLIENT_SECRET=
OAUTH_MICROSOFT_TENANT_ID=
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_OKTA_DOMAIN=
OAUTH_OKTA_CLIENT_ID=
OAUTH_OKTA_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# ─── LLM Judge ────────────────────────────────────────
LLM_JUDGE_ENABLED=false
LLM_ROUTER_URL=
AWS_REGION=us-east-1

# ─── API ───────────────────────────────────────────────
SKILLHUB_API_URL=http://localhost:8000
VITE_API_URL=http://localhost:8000

# ─── MCP Server ───────────────────────────────────────
SKILLHUB_MCP_API_BASE_URL=http://localhost:8000
SKILLHUB_MCP_SKILLS_DIR=~/.claude/skills
SKILLHUB_MCP_HOST=127.0.0.1
SKILLHUB_MCP_PORT=8001
SKILLHUB_MCP_DEBUG=false

# ─── Tracing (local dev) ─────────────────────────────
OTEL_TRACES_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
