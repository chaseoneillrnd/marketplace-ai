# Dependencies
node_modules/
.venv/

# Build
dist/
.nx/cache/
.nx/workspace-data/

# Environment
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Docker
docker-compose.override.yml

# Worktrees
.worktrees/

# Runtime PID file written by mise dev scripts — never commit
.dev-pids

# Playwright MCP session data (browser state, auth storage)
.playwright-mcp/

# Superpowers skill trace artefacts (repomix snapshots, console logs)
.claude/skills/trace/*.json
.claude/skills/trace/*.log

# Coverage artefacts at any subdirectory depth (supplements root-level rules above)
**/htmlcov/
**/.coverage
**/coverage.xml
**/lcov.info
